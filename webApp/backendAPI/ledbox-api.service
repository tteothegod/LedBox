[Unit]
Description=ledProject REST API
After=network.target

[Service]
User=root
EnvironmentFile=/etc/default/ledbox
WorkingDirectory=/home/magodi12/LedBox/ledProject
ExecStart=/usr/bin/node /home/magodi12/LedBox/webApp/backendAPI/index.js
Restart=on-failure
RestartSec=5
LimitNOFILE=4096

[Install]
WantedBy=multi-user.target