# name=Makefile

CXX := g++
# Compiler flags (change -O2/-std as you like). Avoid -march=native when cross-building for Pi.
CXXFLAGS := -O2 -std=c++17 -Wall -Wextra -MMD -MP

# rpi ws281x directory (adjust if your include/lib lives elsewhere)
RPI_WS281X_DIR := $(HOME)/rpi_ws281x
RPI_WS281X_INC := $(RPI_WS281X_DIR)
RPI_WS281X_LIB := $(RPI_WS281X_DIR)

# pkg-config split into compile flags and link libs (try opencv4, fall back to opencv)
OPENCV_CFLAGS := $(shell pkg-config --cflags opencv4 2>/dev/null || pkg-config --cflags opencv 2>/dev/null)
OPENCV_LIBS   := $(shell pkg-config --libs   opencv4 2>/dev/null || pkg-config --libs   opencv 2>/dev/null)

JSONCPP_CFLAGS := $(shell pkg-config --cflags jsoncpp 2>/dev/null || true)
JSONCPP_LIBS   := $(shell pkg-config --libs   jsoncpp 2>/dev/null || true)

MICROHTTPD_CFLAGS := $(shell pkg-config --cflags libmicrohttpd 2>/dev/null || true)
MICROHTTPD_LIBS := $(shell pkg-config --libs   libmicrohttpd 2>/dev/null || true)



# Linker flags and libraries (libraries must come after object files)
LDFLAGS := -L$(RPI_WS281X_LIB)
LDLIBS  := -lws2811 -lwiringPi $(OPENCV_LIBS) $(JSONCPP_LIBS) $(MICROHTTPD_LIBS)

# Targets
TARGETS := ledSyncVideo calibrate ledboxMain ledbox-api

# Sources
COMMON_SRC := src/led_strip.cpp src/saveLoadConfig.cpp
SRC_LSV := src/ledSyncVideo.cpp
SRC_CALIBRATE := src/calibrate.cpp
SRC_LEDBOX_MAIN := src/ledboxMain.cpp
SRC_LEDBOX_API := src/ledbox-api.cpp
SRC_LIGHT_TEST := src/lightTest.cpp
SRC_LEDBOX_UTILS := src/ledbox_utils.cpp

# Objects
OBJ_COMMON := $(COMMON_SRC:.cpp=.o)
OBJ_LSV := $(SRC_LSV:.cpp=.o)
OBJ_CALIBRATE := $(SRC_CALIBRATE:.cpp=.o)
OBJ_LEDBOX_MAIN := $(SRC_LEDBOX_MAIN:.cpp=.o)
OBJ_LEDBOX_API := $(SRC_LEDBOX_API:.cpp=.o)
OBJ_LIGHT_TEST := $(SRC_LIGHT_TEST:.cpp=.o)
OBJ_LEDBOX_UTILS := $(SRC_LEDBOX_UTILS:.cpp=.o)

ALL_OBJS := $(OBJ_COMMON) $(OBJ_LSV) $(OBJ_CALIBRATE) $(OBJ_LEDBOX_MAIN) $(OBJ_LEDBOX_API) $(OBJ_LIGHT_TEST) $(OBJ_LEDBOX_UTILS)

.PHONY: all clean run-lsv run-calibrate run-ledbox run-light-test

all: $(TARGETS)

ledSyncVideo: $(OBJ_COMMON) $(OBJ_LSV)
	$(CXX) $(LDFLAGS) -o $@ $^ $(LDLIBS)

calibrate: $(OBJ_COMMON) $(OBJ_CALIBRATE)
	$(CXX) $(LDFLAGS) -o $@ $^ $(LDLIBS)

ledboxMain: $(OBJ_COMMON) $(OBJ_LEDBOX_MAIN) $(OBJ_LEDBOX_UTILS)
	$(CXX) $(LDFLAGS) -o $@ $^ $(LDLIBS)

lightTest: $(OBJ_COMMON) $(OBJ_LIGHT_TEST)
	$(CXX) $(LDFLAGS) -o $@ $^ $(LDLIBS)

ledbox-api: $(OBJ_COMMON) $(OBJ_LEDBOX_API) $(OBJ_LEDBOX_UTILS)
	$(CXX) $(LDFLAGS) -o $@ $^ $(LDLIBS)

# Generic compile rule: uses pkg-config cflags for compile-time includes
%.o: %.cpp
	$(CXX) $(CXXFLAGS) $(OPENCV_CFLAGS) $(JSONCPP_CFLAGS) $(MICROHTTPD_CFLAGS) -I$(RPI_WS281X_INC) -c $< -o $@

# Include autogenerated dependency files
-include $(ALL_OBJS:.o=.d)

run-lsv: ledSyncVideo
	./ledSyncVideo

run-calibrate: calibrate
	./calibrate

run-ledbox: ledboxMain
	./ledboxMain

run-light-test: lightTest
	./lightTest

clean:
	rm -f $(TARGETS) $(ALL_OBJS) $(ALL_OBJS:.o=.d)