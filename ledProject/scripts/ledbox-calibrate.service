[Unit]
Description=Service that runs calibrate, that allows the status of the program to be tracked.
After=network.target

[Service]
Type=oneshot
ExecStart=/home/magodi12/LedBox/ledProject/calibrate --run-once
EnvironmentFile=/etc/default/ledbox
WorkingDirectory=/home/magodi12/LedBox/ledProject
RemainAfterExit=no

[Install]
WantedBy=multi-user.target
